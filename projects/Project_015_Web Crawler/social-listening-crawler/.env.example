# Taiwan Social Media Keyword Monitoring System
# Copy to .env and fill in your values

# Database (SQLite for development, PostgreSQL for production)
# DATABASE_URL=sqlite:///./social_listening.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/social_listening

# OpenAI API (optional - falls back to rule-based AI if not set)
OPENAI_API_KEY=

# Google Custom Search API (optional - falls back to mock search if not set)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Demo mode (true = skip real scraping, use mock data)
DEMO_MODE=true

# Notification (future: SMTP settings for email alerts)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@company.com
# SMTP_PASS=
