generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model ParkingRecord {
  id             Int       @id @default(autoincrement())
  plateNumber    String    @map("plate_number")
  vehicleType    String    @default("temporary") @map("vehicle_type")
  entryTime      DateTime  @default(now()) @map("entry_time")
  exitTime       DateTime? @map("exit_time")
  parkingMinutes Int?      @map("parking_minutes")
  feeAmount      Int?      @default(0) @map("fee_amount")
  paymentStatus  String    @default("unpaid") @map("payment_status")
  paymentMethod  String?   @map("payment_method")
  status         String    @default("parked") @map("status")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  payments       Payment[]

  @@map("parking_records")
}

model Payment {
  id              Int           @id @default(autoincrement())
  parkingRecordId Int           @map("parking_record_id")
  plateNumber     String        @map("plate_number")
  amount          Int
  paymentMethod   String        @map("payment_method")
  paidAt          DateTime      @default(now()) @map("paid_at")
  status          String        @default("completed")
  createdAt       DateTime      @default(now()) @map("created_at")
  parkingRecord   ParkingRecord @relation(fields: [parkingRecordId], references: [id])

  @@map("payments")
}

model MonthlyCar {
  id          Int      @id @default(autoincrement())
  plateNumber String   @unique @map("plate_number")
  ownerName   String   @map("owner_name")
  phone       String
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("monthly_cars")
}

model Blacklist {
  id          Int      @id @default(autoincrement())
  plateNumber String   @unique @map("plate_number")
  reason      String
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blacklist")
}

model RateSetting {
  id               Int      @id @default(autoincrement())
  freeMinutes      Int      @default(30) @map("free_minutes")
  hourlyRate       Int      @default(40) @map("hourly_rate")
  dailyMaxFee      Int      @default(300) @map("daily_max_fee")
  exitGraceMinutes Int      @default(15) @map("exit_grace_minutes")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("rate_settings")
}

model ParkingLotSetting {
  id           Int      @id @default(autoincrement())
  lotName      String   @default("停車場") @map("lot_name")
  totalSpaces  Int      @default(100) @map("total_spaces")
  usedSpaces   Int      @default(0) @map("used_spaces")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("parking_lot_settings")
}

model EventLog {
  id          Int      @id @default(autoincrement())
  plateNumber String?  @map("plate_number")
  eventType   String   @map("event_type")
  description String
  operator    String?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("event_logs")
}
